# ===========================================
# LIVECART BACKEND - Environment Variables
# ===========================================

# -------------------------------------------
# Application
# -------------------------------------------
APP_ENV=development
PORT=3001

# -------------------------------------------
# Database (OBRIGATORIO)
# -------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/livecart?sslmode=disable

# -------------------------------------------
# Clerk Authentication (OBRIGATORIO)
# Obtenha em: Clerk Dashboard → API Keys
# -------------------------------------------
# Frontend API domain (ex: your-app.clerk.accounts.dev)
CLERK_FRONTEND_API=

# Secret Key para Backend API (sk_live_xxx ou sk_test_xxx)
# Obtenha em: Clerk Dashboard → API Keys → Secret keys
CLERK_SECRET_KEY=

# Webhook secret (opcional em dev local)
# Obtenha em: Clerk Dashboard → Webhooks → seu endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# URL do frontend (para redirect de convites)
FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# AWS (opcional - para SQS worker)
# -------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SQS_QUEUE_URL=

# -------------------------------------------
# Integration Layer (opcional - habilita integrações)
# -------------------------------------------
# Chave AES-256 para criptografia de credenciais
# Gerar com: openssl rand -base64 32
ENCRYPTION_KEY=

# URL base para callbacks OAuth e webhooks
# Em dev local com tunnel: https://livecart-api.loca.lt
# Em produção: https://api.livecart.com
WEBHOOK_BASE_URL=https://livecart-api.loca.lt

# Mercado Pago OAuth App
# Obtenha em: Mercado Pago Developers → Sua aplicação → Credenciais
MERCADO_PAGO_APP_ID=
MERCADO_PAGO_APP_SECRET=
# Set to "true" to get TEST credentials via OAuth (for sandbox testing with test cards)
MERCADO_PAGO_TEST_MODE=false

# Tiny ERP OAuth App
# Obtenha em: Tiny ERP → Configurações → Integrações → API
TINY_CLIENT_ID=
TINY_CLIENT_SECRET=

# -------------------------------------------
# Instagram/Meta Integration
# -------------------------------------------
# Obtenha em: Meta for Developers → Seu App → App Settings → Basic
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Token para verificação de webhooks (você define)
INSTAGRAM_VERIFY_TOKEN=livecart_verify_token
