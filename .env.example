# ===========================================
# LIVECART BACKEND - Environment Variables
# ===========================================

# -------------------------------------------
# Application
# -------------------------------------------
APP_ENV=development
PORT=3001

# -------------------------------------------
# Database (OBRIGATORIO)
# -------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/livecart?sslmode=disable

# -------------------------------------------
# Clerk Authentication (OBRIGATORIO)
# Obtenha o dominio em: Clerk Dashboard → API Keys
# Ex: your-app.clerk.accounts.dev
# -------------------------------------------
CLERK_FRONTEND_API=

# Webhook secret (opcional em dev local)
# Obtenha em: Clerk Dashboard → Webhooks → seu endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# -------------------------------------------
# AWS (opcional - para SQS worker)
# -------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SQS_QUEUE_URL=
